<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OrGestion Pro - ArtisansGN</title>
    
    <link rel="apple-touch-icon" href="https://img.icons8.com/fluency/300/gold-bars.png">
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluency/300/gold-bars.png">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#0f172a"> <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        .modal-active { display: flex !important; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.3); border-radius: 10px; }
        /* Empêche le défilement inutile sur mobile */
        body { touch-action: manipulation; }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-900 to-blue-950 min-h-screen p-4 sm:p-8 font-sans text-white">

    <div class="max-w-2xl mx-auto space-y-6">
        <div class="bg-white/10 backdrop-blur-md border border-white/10 p-6 rounded-[2rem] flex justify-between items-center shadow-2xl">
            <div>
                <h1 class="text-2xl font-black tracking-tighter text-yellow-500">OrGestion <span class="text-white font-light text-sm tracking-normal italic block">v2.0 Premium</span></h1>
            </div>
            <div id="dateDuJour" class="text-right text-xs font-bold text-blue-300 uppercase tracking-widest"></div>
        </div>

        <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-[2.5rem] shadow-2xl">
            <div class="grid grid-cols-1 gap-6">
                <div class="bg-blue-600/20 rounded-3xl p-5 border border-blue-400/20">
                    <label class="text-[10px] font-black text-blue-300 uppercase tracking-widest block mb-2">Fonds Disponibles (GNF)</label>
                    <input type="number" id="capital" value="20000000" oninput="calculerTotal()" class="bg-transparent text-3xl font-black w-full outline-none">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-white/40 uppercase ml-2 tracking-widest">Poids (g)</label>
                        <input type="number" id="poids" oninput="calculerTotal()" placeholder="0.00" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-lg font-bold outline-none focus:border-yellow-500/50">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-white/40 uppercase ml-2 tracking-widest">Prix / g</label>
                        <input type="number" id="prixGramme" oninput="calculerTotal()" placeholder="0" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-lg font-bold outline-none focus:border-yellow-500/50">
                    </div>
                </div>

                <div class="bg-black/40 rounded-3xl p-6 border border-white/5 flex justify-between items-center">
                    <span class="text-xs font-bold text-gray-500 uppercase">Reste Estimé</span>
                    <span id="restePoche" class="text-emerald-400 font-black text-xl font-mono">20 000 000 GNF</span>
                </div>

                <button onclick="enregistrerAchat()" class="w-full py-5 bg-gradient-to-r from-yellow-600 to-yellow-400 text-black rounded-2xl font-black text-lg shadow-xl shadow-yellow-600/20 hover:scale-[1.01] active:scale-95 transition-all">
                    ENREGISTRER LA TRANSACTION
                </button>
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[2.5rem] p-8 shadow-xl">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-black text-lg tracking-tight uppercase">Journal des Achats</h3>
                <button onclick="toggleModal(true)" class="text-[10px] font-bold text-red-400/60 hover:text-red-400 uppercase tracking-widest">Vider le journal</button>
            </div>
            <div id="historiqueListe" class="space-y-3 max-h-[350px] overflow-y-auto pr-2"></div>
        </div>
    </div>

    <div id="confirmModal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm hidden items-center justify-center p-4 z-50">
        <div class="bg-slate-900 border border-white/10 p-8 rounded-[2rem] max-w-sm w-full shadow-2xl text-center">
            <div class="text-4xl mb-4">⚠️</div>
            <h4 class="text-xl font-bold mb-2">Effacer le journal ?</h4>
            <p class="text-gray-400 text-sm mb-8">Cette action est irréversible. Toutes les données enregistrées seront perdues.</p>
            <div class="flex gap-4">
                <button onclick="toggleModal(false)" class="flex-1 py-3 bg-white/5 rounded-xl font-bold">Annuler</button>
                <button onclick="clearHistory()" class="flex-1 py-3 bg-red-500 rounded-xl font-bold">Confirmer</button>
            </div>
        </div>
    </div>

    <script>
        let achats = JSON.parse(localStorage.getItem('achatsOr')) || [];
        document.getElementById('dateDuJour').innerText = new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });

        function formatArgent(n) { return new Intl.NumberFormat('fr-FR').format(n).replace(/\u202f|\u00a0/g, ' '); }

        function calculerTotal() {
            const poids = parseFloat(document.getElementById('poids').value) || 0;
            const prix = parseFloat(document.getElementById('prixGramme').value) || 0;
            const cap = parseFloat(document.getElementById('capital').value) || 0;
            document.getElementById('restePoche').innerText = formatArgent(cap - (poids * prix)) + " GNF";
        }

        function toggleModal(show) { document.getElementById('confirmModal').classList.toggle('modal-active', show); }

        function enregistrerAchat() {
            const p = document.getElementById('poids').value;
            const pr = document.getElementById('prixGramme').value;
            const cap = document.getElementById('capital').value;
            if (!p || !pr) return;

            const achat = { id: Date.now(), poids: p, prix: pr, total: p * pr, capital: cap, date: new Date().toLocaleString('fr-FR') };
            achats.unshift(achat);
            localStorage.setItem('achatsOr', JSON.stringify(achats));
            document.getElementById('poids').value = '';
            document.getElementById('prixGramme').value = '';
            renderHistorique();
            calculerTotal();
        }

        function renderHistorique() {
            const container = document.getElementById('historiqueListe');
            if (achats.length === 0) {
                container.innerHTML = '<p class="text-center text-white/20 py-10 italic">Aucune donnée.</p>';
                return;
            }
            container.innerHTML = achats.map(a => `
                <div onclick="genererPDFSpecifique(${a.id})" class="group bg-white/5 border border-white/5 p-4 rounded-2xl flex justify-between items-center hover:bg-yellow-500 hover:text-black cursor-pointer transition-all">
                    <div>
                        <div class="font-black text-lg">${a.poids} g</div>
                        <div class="text-[10px] uppercase font-bold opacity-60">${a.date}</div>
                    </div>
                    <div class="text-right">
                        <div class="font-black">${formatArgent(a.total)} GNF</div>
                        <div class="text-[10px] font-bold opacity-60 italic">Cliquer pour le reçu 📄</div>
                    </div>
                </div>
            `).join('');
        }

        function clearHistory() {
            achats = [];
            localStorage.removeItem('achatsOr');
            renderHistorique();
            toggleModal(false);
        }

        function genererPDFSpecifique(id) {
            const a = achats.find(x => x.id === id);
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            const reste = a.capital - a.total;

            doc.setFillColor(25, 30, 45); doc.rect(0, 0, 210, 50, 'F');
            doc.setTextColor(212, 175, 55); doc.setFontSize(24); doc.setFont("helvetica", "bold");
            doc.text("REÇU D'ACHAT D'OR", 20, 30);
            doc.setTextColor(255, 255, 255); doc.setFontSize(9); doc.text(`DATE : ${a.date}`, 140, 30);

            doc.setTextColor(40, 40, 40); doc.setFontSize(12); doc.text("DÉTAILS DE L'OPÉRATION", 20, 70);
            doc.line(20, 72, 80, 72);

            doc.setFillColor(248, 249, 250); doc.rect(20, 80, 170, 60, 'F');
            doc.text(`Quantité : ${a.poids} g`, 30, 95);
            doc.text(`Prix Gramme : ${formatArgent(a.prix)} GNF`, 30, 110);
            
            doc.setFillColor(212, 175, 55); doc.rect(20, 125, 170, 15, 'F');
            doc.setTextColor(255, 255, 255); doc.setFont("helvetica", "bold");
            doc.text("TOTAL PAYÉ :", 30, 135); doc.text(`${formatArgent(a.total)} GNF`, 130, 135);

            doc.setTextColor(25, 30, 45); doc.setFont("helvetica", "normal");
            doc.text(`Fonds de départ : ${formatArgent(a.capital)} GNF`, 20, 170);
            doc.setTextColor(0, 128, 0); doc.text(`RESTE À RENDRE : ${formatArgent(reste)} GNF`, 20, 180);

            doc.save(`Recu_${a.id}.pdf`);
        }

        renderHistorique();
    </script>
</body>
</html>
